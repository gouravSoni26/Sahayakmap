# Supabase
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbG...
SUPABASE_SERVICE_KEY=eyJhbG...

# Claude API (primary LLM)
ANTHROPIC_API_KEY=sk-ant-...

# LLM config — "anthropic" | "ollama" | "groq"
LLM_PROVIDER=anthropic
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:1b
GROQ_API_KEY=gsk_...

# Open-Meteo (no key needed)
OPEN_METEO_BASE_URL=https://api.open-meteo.com/v1

# App config
BRIEFING_INTERVAL_MIN=15
DATA_REFRESH_INTERVAL_SEC=60
SIMULATION_MODE=false
LLM_FALLBACK_TO_TEMPLATES=true
LLM_MAX_RETRIES=2
LLM_TIMEOUT_SEC=60
LOG_LEVEL=INFO
# CORS: comma-separated list of allowed origins (no spaces around commas)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Frontend (Vite) — copy to frontend/.env
VITE_API_BASE_URL=http://localhost:8000
VITE_MAP_CENTER_LAT=20.46
VITE_MAP_CENTER_LNG=85.88
VITE_MAP_DEFAULT_ZOOM=8
